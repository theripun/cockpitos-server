{
    "name": "sandbox-api",
    "version": "1.0.0",
    "description": "NestJS API server with cookie sessions, CSRF, and WebAuthn passkeys",
    "author": "",
    "private": true,
    "packageManager": "pnpm@11.7.0",
    "license": "MIT",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "pnpm run start:prod",
        "dev": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --watch",
        "start:debug": "NODE_OPTIONS=--disable-warning=DEP0190 nest start --debug --watch",
        "start:prod": "node dist/src/main.js",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:clean": "node -r tsconfig-paths/register -r ts-node/register clean-data.ts",
        "stress-test": "node -r tsconfig-paths/register -r ts-node/register stress-test-accounts.ts",
        "monitor-load": "node -r tsconfig-paths/register -r ts-node/register monitor-load.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.734.0",
        "@aws-sdk/s3-request-presigner": "^3.734.0",
        "@nestjs/common": "^10.4.0",
        "@nestjs/config": "^3.2.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/platform-ws": "^10.4.0",
        "@nestjs/swagger": "^7.4.0",
        "@nestjs/throttler": "^6.2.0",
        "@nestjs/websockets": "^10.4.0",
        "@simplewebauthn/server": "^10.0.0",
        "@types/ssh2": "^1.15.5",
        "argon2": "^0.40.0",
        "axios": "^1.13.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "cookie": "^1.1.1",
        "cookie-parser": "^1.4.6",
        "date-fns": "^4.1.0",
        "dotenv": "^16.4.0",
        "drizzle-orm": "^0.33.0",
        "express-session": "^1.19.0",
        "geoip-lite": "^2.0.0",
        "helmet": "^7.1.0",
        "nestjs-pino": "^4.1.0",
        "nodemailer": "^8.0.1",
        "pg": "^8.12.0",
        "pino": "^10.3.0",
        "pino-http": "^10.5.0",
        "pino-pretty": "^11.2.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "ssh2": "^1.17.0",
        "ua-parser-js": "^2.0.9",
        "uuid": "^10.0.0",
        "ws": "^8.19.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.0",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/testing": "^10.4.0",
        "@simplewebauthn/types": "^10.0.0",
        "@types/cookie": "^0.6.0",
        "@types/cookie-parser": "^1.4.7",
        "@types/express": "^4.17.21",
        "@types/express-session": "^1.18.2",
        "@types/geoip-lite": "^1.4.4",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.14.0",
        "@types/nodemailer": "^7.0.10",
        "@types/pg": "^8.11.6",
        "@types/supertest": "^6.0.2",
        "@types/ua-parser-js": "^0.7.39",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "drizzle-kit": "^0.24.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^29.7.0",
        "prettier": "^3.3.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.0",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.5.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
