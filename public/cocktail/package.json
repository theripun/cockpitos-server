{
  "name": "cocktail-agent",
  "version": "1.0.0",
  "description": "Reglook Cocktail Agent",
  "packageManager": "pnpm@11.7.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "package": "pkg ."
  },
  "bin": "dist/index.js",
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [],
    "targets": [
      "node18-linux-x64",
      "node18-linux-arm64"
    ]
  },
  "dependencies": {
    "arg": "^5.0.2",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "systeminformation": "^5.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.1.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
