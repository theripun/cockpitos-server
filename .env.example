# Server
NODE_ENV=production
PORT=9100
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cockpit_db

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Session
SESSION_TTL_SECONDS=604800

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# WebAuthn / Passkeys
RP_NAME="Cockpit Production"
RP_ID=localhost
RP_ORIGIN=http://localhost:3000
WEBAUTHN_CHALLENGE_TTL_SECONDS=300

# Cockpit
COCKPIT_SECRET_KEY=change-me-to-at-least-32-chars-long-secret-key-89899

# Storage (R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cockpit-storage
R2_PUBLIC_BASE_URL=
R2_REGION=auto

# Mail (local development placeholders)
MAIL_TRANSPORT=log
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=local
SMTP_PASS=local
FROM_EMAIL=no-reply@localhost.test
